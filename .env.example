# Copy to .env and fill values when real sources or delivery are enabled.
APP_ENV=local
SAMPLE_MODE=true
DATABASE_URL=sqlite:///./data/family_newsletter.db
CONFIG_FILE=config.example.yaml

NEWSLETTER_TIMEZONE=America/Los_Angeles
NEWSLETTER_SEND_TIME=08:00
NEWSLETTER_ENABLED=false

EMAIL_PROVIDER=smtp
EMAIL_FROM=your-gmail@gmail.com
# Comma-separated list of recipient addresses.
EMAIL_RECIPIENTS=

# Gmail SMTP. SMTP_PASSWORD must be a 16-char Gmail App Password (Google Account
# -> Security -> 2-Step Verification -> App passwords), NOT your login password.
# This file (.env) is git-ignored, so credentials are never committed.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=

RESEND_API_KEY=

WEATHER_PROVIDER=sample
WEATHER_API_KEY=

